<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.gametools.fstools"
    android:versionCode="1"
    android:versionName="1.0" >

    <!-- Установка поддержки версий: минимум Android 2.3 (API 9), цель Android 8.0 (API 26) -->
    <uses-sdk 
        android:minSdkVersion="9" 
        android:targetSdkVersion="26" />

    <!-- Разрешения на чтение и запись файлов во внутренней памяти и на SD-карте -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/icon"
        android:label="@string/app_name"
        android:theme="@android:style/Theme.Black.NoTitleBar" >

        <!-- 
          Главный экран файлового менеджера (MainActivity).
          Флаг configChanges гарантирует, что при повороте экрана из Портретного в Альбомный 
          (и перестроении панелей бок о бок) операционная система НЕ будет уничтожать Activity. 
          Это предотвратит обрыв фонового потока копирования/перемещения файлов.
        -->
        <activity
            android:name="com.gametools.fstools.MainActivity"
            android:label="@string/app_name"
            android:configChanges="orientation|screenSize|keyboardHidden" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
