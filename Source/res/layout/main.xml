<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout 
        android:id="@+id/layoutPathHeaders"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#111111"
        android:padding="5dp">
        <TextView android:id="@+id/tvLeftPathHeader"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:textColor="#AAAAAA" android:textSize="12sp" android:singleLine="true" android:ellipsize="start"/>
        <TextView android:id="@+id/tvRightPathHeader"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:textColor="#555555" android:textSize="12sp" android:singleLine="true" android:ellipsize="start" android:gravity="right"/>
    </LinearLayout>

    <android.support.v4.view.ViewPager
        android:id="@+id/panelViewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/layoutProgressBlock"
        android:layout_below="@id/layoutPathHeaders" />

    <LinearLayout
        android:id="@+id/layoutProgressBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_above="@+id/layoutBottomToolbar"
        android:visibility="gone"
        android:padding="8dp">
        <ProgressBar android:id="@+id/progressBar" style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent" android:layout_height="wrap_content" />
        <TextView android:id="@+id/tvStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/layoutBottomToolbar"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_alignParentBottom="true"
        android:background="#222222" android:padding="4dp">
        <Button android:id="@+id/btnTcCopy" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Копировать"/>
        <Button android:id="@+id/btnTcMove" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Переместить"/>
        <Button android:id="@+id/btnTcDelete" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Удалить"/>
    </LinearLayout>
</RelativeLayout>
